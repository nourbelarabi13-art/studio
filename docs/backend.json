
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Metadata for a user in the sanctuary.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "bio": { "type": "string", "description": "A short manifesto of the dreamer's spirit." },
        "status": { "type": "string", "description": "Current mood or activity (e.g., 'Writing my first myth')." },
        "avatar": { "type": "string", "description": "Base64 data URI or URL of the user's avatar." },
        "role": { "type": "string", "enum": ["writer", "reader"], "default": "reader" },
        "ageConfirmed": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "followerCount": { "type": "integer", "default": 0 },
        "followingCount": { "type": "integer", "default": 0 },
        "totalViews": { "type": "integer", "default": 0 },
        "totalLikes": { "type": "integer", "default": 0 },
        "publishedCount": { "type": "integer", "default": 0 },
        "achievements": { "type": "array", "items": { "type": "string" } },
        "language": { "type": "string", "enum": ["en", "ar", "fr"] },
        "country": { "type": "string" },
        "readingPreferences": {
          "type": "object",
          "properties": {
            "fontSize": { "type": "number" },
            "lineHeight": { "type": "number" },
            "mode": { "type": "string", "enum": ["light", "sepia", "lavender", "midnight"] }
          }
        }
      },
      "required": ["uid", "username", "email", "ageConfirmed", "role"]
    },
    "Novel": {
      "title": "Novel",
      "description": "A chronicle manifested by a traveler.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "authorId": { "type": "string" },
        "authorUsername": { "type": "string" },
        "genres": { "type": "array", "items": { "type": "string" } },
        "publishedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "coverImage": { "type": "string" },
        "isDraft": { "type": "boolean" },
        "views": { "type": "integer", "default": 0 },
        "likes": { "type": "integer", "default": 0 },
        "language": { "type": "string", "enum": ["en", "ar", "fr"] },
        "country": { "type": "string" },
        "poll": {
          "type": "object",
          "properties": {
            "question": { "type": "string" },
            "options": { "type": "array", "items": { "type": "string" } },
            "active": { "type": "boolean" }
          }
        }
      },
      "required": ["title", "content", "authorId", "genres", "isDraft"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A community whisper regarding a chronicle.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "text": { "type": "string" },
        "parentId": { "type": "string", "description": "ID of parent comment if this is a reply" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "text", "createdAt"]
    },
    "AiChatMessage": {
      "title": "AI Chat Message",
      "description": "A message between a user and the celestial Oracle.",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["user", "model"] },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["role", "content", "createdAt"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "User profile scroll."
    },
    "/novels/{novelId}": {
      "schema": "Novel",
      "description": "Chronicle content."
    },
    "/users/{uid}/aiChats/{chatId}": {
      "schema": "AiChatMessage",
      "description": "Whispers between dreamer and Oracle."
    }
  }
}
