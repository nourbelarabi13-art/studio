
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Metadata for a user in the sanctuary.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "ageConfirmed": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "username", "email", "ageConfirmed"]
    },
    "Novel": {
      "title": "Novel",
      "description": "A chronicle manifested by a traveler.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "authorId": { "type": "string" },
        "authorUsername": { "type": "string" },
        "genres": { "type": "array", "items": { "type": "string" } },
        "publishedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "coverImage": { "type": "string" },
        "isDraft": { "type": "boolean" },
        "views": { "type": "integer", "default": 0 },
        "likes": { "type": "integer", "default": 0 }
      },
      "required": ["title", "content", "authorId", "genres", "isDraft"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "The user's personal profile scroll."
    },
    "/novels/{novelId}": {
      "schema": "Novel",
      "description": "A collection of all manifested chronicles and fragments."
    }
  }
}
