
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Metadata for a user in the sanctuary.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "bio": { "type": "string", "description": "A short manifesto of the dreamer's spirit." },
        "role": { "type": "string", "enum": ["writer", "reader"], "default": "reader" },
        "ageConfirmed": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "followerCount": { "type": "integer", "default": 0 },
        "followingCount": { "type": "integer", "default": 0 },
        "totalViews": { "type": "integer", "default": 0 },
        "totalLikes": { "type": "integer", "default": 0 },
        "publishedCount": { "type": "integer", "default": 0 },
        "achievements": { "type": "array", "items": { "type": "string" } },
        "language": { "type": "string", "enum": ["en", "ar", "fr"] },
        "country": { "type": "string" }
      },
      "required": ["uid", "username", "email", "ageConfirmed", "role"]
    },
    "Novel": {
      "title": "Novel",
      "description": "A chronicle manifested by a traveler.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "authorId": { "type": "string" },
        "authorUsername": { "type": "string" },
        "genres": { "type": "array", "items": { "type": "string" } },
        "publishedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "coverImage": { "type": "string" },
        "isDraft": { "type": "boolean" },
        "views": { "type": "integer", "default": 0 },
        "likes": { "type": "integer", "default": 0 },
        "language": { "type": "string", "enum": ["en", "ar", "fr"] },
        "country": { "type": "string", "description": "The country of origin for the story." }
      },
      "required": ["title", "content", "authorId", "genres", "isDraft"]
    },
    "ReadingProgress": {
      "title": "Reading Progress",
      "description": "A record of a user's progress through a chronicle.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "novelId": { "type": "string" },
        "novelTitle": { "type": "string" },
        "coverImage": { "type": "string" },
        "authorUsername": { "type": "string" },
        "percentage": { "type": "number" },
        "scrollPosition": { "type": "number" },
        "chapterIndex": { "type": "integer" },
        "lastReadAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "novelId", "percentage"]
    },
    "Bookmark": {
      "title": "Bookmark",
      "description": "A saved chronicle in a user's library.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "novelId": { "type": "string" },
        "novelTitle": { "type": "string" },
        "coverImage": { "type": "string" },
        "authorUsername": { "type": "string" },
        "category": { "type": "string", "enum": ["favorite", "read-later"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "novelId", "category"]
    },
    "Follow": {
      "title": "Follow",
      "description": "A record of a user following another user.",
      "type": "object",
      "properties": {
        "followerId": { "type": "string" },
        "followingId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["followerId", "followingId"]
    },
    "Notification": {
      "title": "Notification",
      "description": "A whisper from the sanctuary regarding community activity.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["like", "comment", "story", "follow"] },
        "message": { "type": "string" },
        "fromUserId": { "type": "string" },
        "fromUserName": { "type": "string" },
        "targetId": { "type": "string", "description": "ID of the novel or comment" },
        "read": { "type": "boolean", "default": false },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "message", "read", "createdAt"]
    },
    "ChatRoom": {
      "title": "Chat Room",
      "description": "A discussion space for writers.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "lastMessageAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "category"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "A message within a chat room.",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "senderName", "text"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "The user's personal profile scroll."
    },
    "/users/{uid}/progress/{novelId}": {
      "schema": "ReadingProgress",
      "description": "The user's reading progress for a specific chronicle."
    },
    "/users/{uid}/bookmarks/{novelId}": {
      "schema": "Bookmark",
      "description": "User's saved chronicles and favorites."
    },
    "/users/{uid}/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "Whispers of community activity sent to a specific user."
    },
    "/novels/{novelId}": {
      "schema": "Novel",
      "description": "A collection of all manifested chronicles and fragments."
    },
    "/follows/{followId}": {
      "schema": "Follow",
      "description": "Users following others. followId is followerId_followingId"
    },
    "/chatRooms/{roomId}": {
      "schema": "ChatRoom",
      "description": "Community discussion rooms."
    },
    "/chatRooms/{roomId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Messages in a specific chat room."
    }
  }
}
