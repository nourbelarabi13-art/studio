
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Metadata for a user in the sanctuary.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "bio": { "type": "string", "description": "A short manifesto of the dreamer's spirit." },
        "role": { "type": "string", "enum": ["writer", "reader"], "default": "reader" },
        "ageConfirmed": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "followerCount": { "type": "integer", "default": 0 },
        "followingCount": { "type": "integer", "default": 0 },
        "totalViews": { "type": "integer", "default": 0 },
        "totalLikes": { "type": "integer", "default": 0 },
        "publishedCount": { "type": "integer", "default": 0 },
        "achievements": { "type": "array", "items": { "type": "string" } },
        "language": { "type": "string", "enum": ["en", "ar", "fr"] },
        "country": { "type": "string" },
        "readingPreferences": {
          "type": "object",
          "properties": {
            "fontSize": { "type": "number" },
            "lineHeight": { "type": "number" },
            "mode": { "type": "string", "enum": ["light", "sepia", "lavender", "midnight"] }
          }
        }
      },
      "required": ["uid", "username", "email", "ageConfirmed", "role"]
    },
    "Novel": {
      "title": "Novel",
      "description": "A chronicle manifested by a traveler.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "authorId": { "type": "string" },
        "authorUsername": { "type": "string" },
        "genres": { "type": "array", "items": { "type": "string" } },
        "publishedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "coverImage": { "type": "string" },
        "isDraft": { "type": "boolean" },
        "views": { "type": "integer", "default": 0 },
        "likes": { "type": "integer", "default": 0 },
        "language": { "type": "string", "enum": ["en", "ar", "fr"] },
        "country": { "type": "string" },
        "poll": {
          "type": "object",
          "properties": {
            "question": { "type": "string" },
            "options": { "type": "array", "items": { "type": "string" } },
            "active": { "type": "boolean" }
          }
        }
      },
      "required": ["title", "content", "authorId", "genres", "isDraft"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A community whisper regarding a chronicle.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "text": { "type": "string" },
        "parentId": { "type": "string", "description": "ID of parent comment if this is a reply" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "text", "createdAt"]
    },
    "EndingVote": {
      "title": "Ending Vote",
      "description": "A user's choice for a story's direction.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "choiceIndex": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "choiceIndex", "createdAt"]
    },
    "ReadingProgress": {
      "title": "Reading Progress",
      "description": "A record of a user's progress through a chronicle.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "novelId": { "type": "string" },
        "percentage": { "type": "number" },
        "lastReadAt": { "type": "string", "format": "date-time" }
      }
    },
    "Bookmark": {
      "title": "Bookmark",
      "description": "A saved chronicle in a user's library.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "novelId": { "type": "string" },
        "category": { "type": "string", "enum": ["favorite", "read-later"] }
      }
    },
    "Notification": {
      "title": "Notification",
      "description": "A whisper from the sanctuary regarding community activity.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["like", "comment", "story", "follow"] },
        "message": { "type": "string" },
        "read": { "type": "boolean", "default": false },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "ChatRoom": {
      "title": "Chat Room",
      "description": "A discussion space for writers.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" }
      }
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "A message within a chat room.",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "User profile scroll."
    },
    "/novels/{novelId}": {
      "schema": "Novel",
      "description": "Chronicle content."
    },
    "/novels/{novelId}/comments/{commentId}": {
      "schema": "Comment",
      "description": "Chronicle discussions."
    },
    "/novels/{novelId}/votes/{userId}": {
      "schema": "EndingVote",
      "description": "Ending preference votes."
    },
    "/users/{uid}/notifications/{notifId}": {
      "schema": "Notification",
      "description": "User whispers."
    },
    "/chatRooms/{roomId}": {
      "schema": "ChatRoom",
      "description": "Community discussion spaces."
    },
    "/chatRooms/{roomId}/messages/{msgId}": {
      "schema": "ChatMessage",
      "description": "Community chat messages."
    }
  }
}
